# ---------------------------------------------------------------------------
# Database (MongoDB Atlas)
# ---------------------------------------------------------------------------
# Connection string from MongoDB Atlas. Include the database name in the path,
# e.g. mongodb+srv://user:pass@cluster.mongodb.net/clothing_stock
MONGODB_URI=
# Optional: override the database name (otherwise taken from the URI)
MONGODB_DB=clothing_stock

# ---------------------------------------------------------------------------
# Authentication (single admin)
# ---------------------------------------------------------------------------
# The password required to log in to the dashboard.
ADMIN_PASSWORD=change-me
# Secret used to sign session JWTs. Use a long random string.
SESSION_SECRET=replace-with-a-long-random-secret
# Optional: email shown for the admin user in the UI.
ADMIN_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Object storage (Backblaze B2, S3-compatible)
# ---------------------------------------------------------------------------
# Application Key ID and Application Key from Backblaze.
B2_KEY_ID=
B2_APP_KEY=
# Bucket name (the bucket must be PUBLIC so uploaded images can be displayed).
B2_BUCKET=
# Region, e.g. us-west-004
B2_REGION=us-west-004
# S3 endpoint for your region, e.g. https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# Optional: override the public base URL used to serve files. If unset, the
# path-style endpoint URL is used: {B2_ENDPOINT}/{B2_BUCKET}/{key}
# B2_PUBLIC_BASE_URL=https://f004.backblazeb2.com/file/your-bucket

# ---------------------------------------------------------------------------
# Local development only
# ---------------------------------------------------------------------------
# Port the API server listens on locally (not used on Vercel).
PORT=8080
# Where the Vite dev server proxies /api requests during local dev.
API_PROXY_TARGET=http://localhost:8080
